JWT_SECRET=replace-with-a-long-random-secret
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=change-me
LOCAL_NETWORK_ONLY=false

# Railway usually injects these automatically when you add a MySQL service.
# Only set them manually if your Railway service is not receiving the shared MySQL vars.
# DB_HOST=
# DB_PORT=3306
# DB_USER=
# DB_PASSWORD=
# DB_NAME=
