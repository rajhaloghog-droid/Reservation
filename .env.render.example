#
# Render deployment notes
# - The web service uses DB_* values.
# - The MySQL private service uses MYSQL_* values.
# - In Render, keep secrets in the dashboard instead of committing them.
#

PORT=10000
HOST=0.0.0.0
LOCAL_NETWORK_ONLY=false

JWT_SECRET=generated-by-render-or-set-in-dashboard
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=change-me

DB_HOST=reservation-mysql
DB_PORT=3306
DB_NAME=reservation_system
DB_USER=reservation_app
DB_PASSWORD=set-this-to-the-same-value-as-MYSQL_PASSWORD

MYSQL_DATABASE=reservation_system
MYSQL_USER=reservation_app
MYSQL_PASSWORD=set-in-render
MYSQL_ROOT_PASSWORD=set-in-render
